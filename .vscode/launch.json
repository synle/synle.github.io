{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/test/${fileBasename}",
      "args": [],
      "runtimeArgs": ["--test"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Run All Tests",
      "type": "node",
      "request": "launch",
      "args": ["--test", "test/*.spec.js"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
