<!DOCTYPE html>
<html lang="en">

<head>
  <title>Resume Variants</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/index.css" />
</head>

<body>
  <div class="paper">
    <article>
      <div><h1>Resume Variants</h1></div>
      <p>Select a resume version below.</p>
    </article>

    <article>
      <section><h3>Available Resumes:</h3></section>
      <div class="col-container" style="gap: var(--spaceSize4);">
        {{#resumes}}
        <div style="padding: var(--spaceSize3); border: var(--borderSize1) solid var(--colorBorderSecondary); border-radius: var(--borderRadius1);">
          <div class="row-container space-between" style="margin-bottom: var(--spaceSize1);">
            <h4>{{name}}</h4>
            <div>
              <a href="/{{htmlFile}}">View HTML</a>
              &nbsp;|&nbsp;
              <a href="/{{pdfFile}}" download>Download PDF</a>
            </div>
          </div>
          <p>{{description}}</p>
        </div>
        {{/resumes}}
      </div>
    </article>
  </div>

  <script>
    (function () {
      document.querySelectorAll('a').forEach(function (a) {
        a.setAttribute('target', '_blank');
        a.setAttribute('rel', 'noopener noreferrer');
      });
    })();
  </script>
</body>

</html>
